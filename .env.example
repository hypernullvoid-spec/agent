# Copy this file to .env and fill in the keys for the providers you use.

# ── LLM provider keys ────────────────────────────────────────────────
# Anthropic (default provider): https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=

# ── model selection (spec: [provider:]model[@base_url]) ─────────────
# SWARN_MODEL=claude-sonnet-4-6           # global default
# SWARN_CODE_MODEL=claude-sonnet-4-6      # search engine: code generation
# SWARN_FEEDBACK_MODEL=openai:gpt-4o-mini # search engine: cheap review model

# ── execution ────────────────────────────────────────────────────────
# SWARN_SANDBOX=docker|subprocess         # force; default: auto-detect
# SWARN_EXEC_TIMEOUT=300                  # per-call timeout (seconds)
# SWARN_SANDBOX_IMAGE=python:3.11-slim

# ── V3: search + learning ────────────────────────────────────────────
# SWARN_SEARCH_WORKERS=4                  # parallel solution nodes
# SWARN_KNOWLEDGE_DIR=./knowledge         # playbook + run archive location
# SWARN_MAX_ITERATIONS=30                 # ReAct loop iteration cap
# SWARN_CONTEXT_CHAR_BUDGET=400000        # compaction threshold (chars)
